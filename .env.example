# ------------------------------------------------------------------------------
# 🎯 OPPORTUNITY HUNTER AI AGENT - ENVIRONMENT CONFIGURATION TEMPLATE
# ------------------------------------------------------------------------------
# Instructions: Copy this file, rename it to `.env` in the same directory,
# and fill in your API credentials.
# ------------------------------------------------------------------------------

# 1. GENERATIVE AI EXTRACTION KEYS (At least one is recommended)
# ------------------------------------------------------------------------------
# [OPTIONAL but highly recommended] Groq API Key: Used as the primary, lightning-fast
# extraction engine running Llama-3.3-70b-versatile. Get a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# [OPTIONAL] Google Gemini API Key: Supported for failover/extension.
# Can support a single key, comma-separated keys for automatic rotation, or
# numbered keys (GEMINI_API_KEY_1, GEMINI_API_KEY_2, etc.)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NOTE: If no keys are specified for Groq or Gemini, the agent automatically falls
# back to a 100% free, unlimited, keyless GPT-4o engine via Pollinations AI.
# This means the agent works out of the box even without Groq or Gemini keys!


# 2. WEB SEARCH API KEYS (At least one is REQUIRED)
# ------------------------------------------------------------------------------
# [PRIMARY] Tavily API Key: The industry standard search engine custom-built for AI agents.
# Sign up and get a free tier (1,000 monthly searches) at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# [FALLBACK] Serper.dev API Key: High-speed Google Search API. Acts as an automatic
# failover backup if Tavily limits are exceeded.
# Sign up and get 2,500 free queries at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here
